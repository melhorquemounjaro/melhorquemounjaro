{
  "buildCommand": "true",
  "installCommand": "true",
  "outputDirectory": "./",
  "routes": [
    {
      "src": "/pagina-de-vendas.html",
      "dest": "/pagina-de-vendas.html"
    },
    {
      "src": "/melhor-que-mounjaro.html",
      "dest": "/melhor-que-mounjaro.html"
    },
    {
      "src": "/melhor-que-mounjaro.pdf",
      "dest": "/melhor-que-mounjaro.pdf"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
